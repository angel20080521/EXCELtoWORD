# 项目环境变量配置
# 复制此文件为 .env.local 或在部署时设置这些变量
# 这里只展示变量名和用途示例，不包含真实数据。

# 项目根目录（自动设置，通常不需要手动修改）
COZE_WORKSPACE_PATH=

# 服务端口
DEPLOY_RUN_PORT=

# 运行环境
NODE_ENV=
COZE_PROJECT_ENV=

# 服务主机与端口
HOSTNAME=
PORT=

# API 密钥（例如 COZE_API_KEY）
COZE_API_KEY=

# Python 脚本环境变量示例
EXCEL_PATH=
WORD_TEMPLATE_PATH=
OUTPUT_DIR=
